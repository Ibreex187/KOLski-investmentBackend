 {
  "name": "server",
  "version": "1.0.0",
  "description": "Investment app backend API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node scripts/dev.js",
    "dev:plain": "nodemon index.js",
    "test": "node --no-warnings ./node_modules/jest/bin/jest.js",
    "test:alerts": "node --no-warnings ./node_modules/jest/bin/jest.js test/analytics_alerts.test.js --runInBand",
    "test:market": "node --no-warnings ./node_modules/jest/bin/jest.js test/market.test.js --runInBand",
    "test:portfolio": "node --no-warnings ./node_modules/jest/bin/jest.js test/portfolio.test.js --runInBand",
    "test:watch": "node --no-warnings ./node_modules/jest/bin/jest.js --watch",
    "check:portfolio": "node check_portfolio.js",
    "test:auth-flow": "node test-auth.js",
    "docs:openapi": "node -e \"const spec=require('./docs/openapi.json'); console.log(JSON.stringify(spec, null, 2));\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "mongoose": "^9.3.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.4",
    "otp-generator": "^4.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
